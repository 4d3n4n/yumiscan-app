# Copier vers .env pour une config unique, OU vers .env.recette / .env.main pour une config par branche :
# - .env.recette = Supabase LOCAL (branche recette, npm run dev)
# - .env.main = Supabase CLOUD (branche main, npm run dev). Voir scripts/env-by-branch.js
#
# Supabase local (Docker) - généré depuis `supabase start`
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=
SUPABASE_URL=

# Clé secrète (service role) - à utiliser uniquement côté serveur / Edge Functions
SUPABASE_SERVICE_ROLE_KEY=

# Base de données directe (optionnel, pour scripts / migrations)
DATABASE_URL=

# Clé API Google Generative AI (Gemini) + (cette clé active aussi le service vision OCR Google)
GEMINI_KEY=

# Optionnel: fallback de modèle si le back-office n'a pas encore renseigné app_config
SCAN_AI_MODEL=gemini-2.5-flash
ASSISTANT_AI_MODEL=gemini-2.5-flash

# Clé API Google Cloud Text to Speech
GOOGLE_CLOUD_TEXT_TO_SPEECH_API_KEY=

# En local : URL du front (Nuxt) pour les redirections Stripe après paiement
SITE_URL=

# Stripe — clé publique (paiement sur la même page). À récupérer : Dashboard Stripe → Développeurs → Clés API → Clé publique (pk_test_...)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# stripe secret key
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Tracking pixels (laisser vide tant que les IDs ne sont pas disponibles)
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_META_PIXEL_ID=
NUXT_PUBLIC_TIKTOK_PIXEL_ID=

# Sentry (monitoring + User Feedback) à mettre dans vercel et github secrets
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_FORCE_ENABLE=false
SENTRY_AUTH_TOKEN=

# Sentry webhook → Discord (Edge Function sentry-webhook)
# Secret de l’Internal Integration Sentry (signature HMAC des webhooks)
SENTRY_WEBHOOK_SECRET=
# URL du webhook Discord (Forum Channel) pour créer les threads
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
